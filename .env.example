# Copy to .env and fill in your own values. The real .env is gitignored.
# Every variable here is OPTIONAL — the site builds and runs without them.
# They only enable specific AI skills / integrations used during development.

# --- Site search (Algolia) ---
# Search-only credentials that mirror the Cloudflare Pages env vars.
# The API key is a public, search-only key (safe to ship in the client bundle).
ALGOLIA_APPLICATION_ID=
ALGOLIA_API_KEY=

# --- Discord skill (optional) ---
# Bot token for the /discord skill. Create at https://discord.com/developers
DISCORD_TOKEN=

# --- Reddit MCP (optional) ---
# App-only authenticated read for the reddit research MCP.
# Create an app at https://www.reddit.com/prefs/apps
REDDIT_AUTH_MODE=authenticated
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT="macos:poe2-research-mcp:1.0 (by /u/your_reddit_username)"
