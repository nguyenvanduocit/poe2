{
  "enabledPlugins": {
    "aio-youtube@aiocean-plugins": true,
    "aio-design-system@aiocean-plugins": true,
    "qmd@qmd": true,
    "aio-kanban@aiocean-plugins": true,
    "claude-annotator-plugin@claude-annotator-plugin": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/content-voice-lint.sh\"" }
        ]
      }
    ]
  }
}
