#===============================================================================================================
# S-TIER ONLY Filter - Path of Exile 2
#===============================================================================================================
# ULTRA STRICT - Only highest value items
# ALL DROP SOUNDS DISABLED
#===============================================================================================================

#===============================================================================================================
# GOD-TIER CURRENCY (Mirror & Divine)
#===============================================================================================================

Show
	BaseType == "Mirror of Kalandra"
	SetFontSize 45
	SetTextColor 255 0 255 255
	SetBorderColor 255 0 255 255
	SetBackgroundColor 255 255 255 255
	PlayEffect Pink
	MinimapIcon 0 Pink Star
	DisableDropSound True

Hide
	BaseType == "Divine Orb"
	DisableDropSound True

