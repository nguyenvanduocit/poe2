	BaseType == "Twilight Reliquary Key" "Olroth's Reliquary Key" "Ritualistic Reliquary Key" "Tangmazu's Reliquary Key" "The Arbiter's Reliquary Key" "The Trialmaster's Reliquary Key" "Xesht's Reliquary Key" "Zarokh's Reliquary Key" "Azmeri Reliquary Key"
	DisableDropSound True

# Fallback: Hide by Class
Hide
	Class == "Vault Keys"
	DisableDropSound True

