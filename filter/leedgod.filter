#===============================================================================================================
# QUEST ITEMS (always show)
#===============================================================================================================

Show
	Class == "Quest Items"
	SetFontSize 36
	SetTextColor 74 230 58 255
	PlayEffect Green
	MinimapIcon 0 Green Pentagon
	DisableDropSound True

#===============================================================================================================
# HIDE ALL CURRENCY (not matched above)
#===============================================================================================================

Hide
	Class == "Stackable Currency" "Incubators"
	DisableDropSound True

#===============================================================================================================
# HIDE ALL OMENS (not matched above)
#===============================================================================================================

Hide
	Class == "Omen"
	DisableDropSound True

#===============================================================================================================
# WAYSTONES (T15-T16 only)
#===============================================================================================================

Show
	WaystoneTier >= 15
	Class == "Waystones"
	SetFontSize 32
	SetTextColor 255 255 255 255
	SetBorderColor 255 0 0 255
	SetBackgroundColor 0 0 0 255
	PlayEffect Red
	MinimapIcon 1 Red Star

Hide
	Class == "Waystones"

#===============================================================================================================
# HIDE ALL UNIQUES (not matched above)
#===============================================================================================================

Hide
	Rarity Unique
	DisableDropSound True

