# Persisted data — refreshable / instance / large mirrors. Not source-of-truth.
data/wiki/               # poe2wiki.net goscrape mirror
data/poedb/              # poe2db.tw mirror per patch
data/pob-source/         # PathOfBuildingCommunity POE2 clone (has own .git/, ~572M)
data/trade-static/       # GGG trade catalog (refreshable from API)
data/character-exports/  # per-character export JSON (instance data)
raw-data/
tmp/*
!tmp/.gitkeep

