# Local PoB upstream clones used as reference only (not part of the site).
# Tracked previously as broken gitlinks (no .gitmodules) → CF clone failed.
references/PathOfBuilding/
references/PathOfBuilding2/

# Per-skill persisted data — moved to data/ in 2026-05-24 refactor.
# Cache + instance data (refreshable from API or per-character), not source-of-truth.
data/pob-source/         # PathOfBuilding git clones per game (has own .git/, ~572M for PoE2)
data/trade-static/       # poe-filters.json + poe-static-cache.json, refreshable
data/character-exports/  # character export JSON (instance, per-account)
tmp/*
!tmp/.gitkeep

# Cloudflare Wrangler cache
.wrangler/

# Claude Code local/runtime files (commit settings.json + skills/, ignore the rest)
.claude/settings.local.json
.claude/scheduled_tasks.lock
.gitnexus

# Large generated reference mirrors (wiki scrapes, DB dumps, PoB source) — do not commit full data
data/poe1-wiki/
data/poe2-wiki/
data/poedb1/
data/poedb2/
raw-data/
data/pob-source/
