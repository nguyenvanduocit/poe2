# POE scripts — generated node_modules (legacy pob1 clone location)
.claude/skills/pob1/scripts/pob1/
.claude/skills/lootfilter/parser/node_modules/

# Local PoB upstream clones used as reference only (not part of the site).
# Tracked previously as broken gitlinks (no .gitmodules) → CF clone failed.
references/PathOfBuilding/
references/PathOfBuilding2/

# Persisted data — refreshable / instance / large mirrors. Not source-of-truth.
# poe2wiki.net goscrape mirror
data/wiki/
# poe2db.tw mirror per patch
data/poedb/
# PathOfBuildingCommunity POE2 clone (has own .git/, ~572M)
data/pob-source/
# GGG trade catalog (refreshable from API)
data/trade-static/
# per-character export JSON (instance data)
data/character-exports/
# curated POE OSS clones for study (each has own .git/, ~1.3G) — ignore clones, keep index README
data/github-research/*
!data/github-research/README.md
raw-data/
tmp/*
!tmp/.gitkeep

# Cloudflare Wrangler cache
.wrangler/

# Claude Code local/runtime files (commit settings.json + skills/, ignore the rest)
.claude/settings.local.json
.claude/scheduled_tasks.lock
.gitnexus

# Collaborative-markdown editing runtime state (Yjs CRDT sidecar)
.collabmd/

# Embedded git repo (Path of Building source) — read locally by build scripts, not shipped
data/pob-source/
