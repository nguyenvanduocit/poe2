dist

# Node dependencies
node_modules

# Logs
logs
*.log

# Misc
.DS_Store
.fleet
.idea

# Local env files
.env
.env.*
!.env.example

# Scraped reference site (538MB, not source code) — allow only app-owned assets
public/*
!public/images/
public/images/*
!public/images/poe-ui/
